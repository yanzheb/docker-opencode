# LaTeX toolchain layered on the base image.
# Build the base first, then pass --build-arg BASE_IMAGE=opencode-gpu if needed.
ARG BASE_IMAGE=opencode-nogpu
FROM ${BASE_IMAGE}

# texlive-full is large (~several GB) but includes all standard packages.
USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
         texlive-full \
         latexmk \
    && rm -rf /var/lib/apt/lists/*
USER agent

WORKDIR /workspace
CMD ["/bin/bash"]
