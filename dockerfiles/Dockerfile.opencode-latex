# Adds a full LaTeX toolchain on top of the base OpenCode image.
# Build the base first (see README Step 5.3), then:
#   docker build -t opencode-latex \
#       -f dockerfiles/Dockerfile.opencode-latex dockerfiles/
#
# Pass --build-arg BASE_IMAGE=opencode-gpu to layer on the GPU base instead.
ARG BASE_IMAGE=opencode-nogpu
FROM ${BASE_IMAGE}

# texlive-full is large (several GB) but pulls in every standard package, so
# projects do not need to guess which texlive-* subset they need. latexmk is
# the usual top-level build driver.
USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
         texlive-full \
         latexmk \
    && rm -rf /var/lib/apt/lists/*
USER agent

WORKDIR /workspace
CMD ["/bin/bash"]
