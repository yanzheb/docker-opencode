FROM docker/sandbox-templates:opencode

# GPU build args. Empty by default; pass --build-arg for GPU support.
# The NVIDIA Container Toolkit injects drivers at runtime—no CUDA inside needed.
ARG NVIDIA_VISIBLE_DEVICES=""
ARG NVIDIA_DRIVER_CAPABILITIES=""
ENV NVIDIA_VISIBLE_DEVICES=${NVIDIA_VISIBLE_DEVICES}
ENV NVIDIA_DRIVER_CAPABILITIES=${NVIDIA_DRIVER_CAPABILITIES}

# Enable truecolor so OpenCode renders its theme correctly.
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV OPENCODE_ENABLE_EXA=1

# Install Pixi globally. PIXI_NO_PATH_UPDATE skips unnecessary shell config.
USER root
RUN curl -fsSL https://pixi.sh/install.sh | PIXI_NO_PATH_UPDATE=1 sh \
    && mv /root/.pixi/bin/pixi /usr/local/bin/pixi \
    && rm -rf /root/.pixi

USER agent

WORKDIR /workspace
CMD ["/bin/bash"]
