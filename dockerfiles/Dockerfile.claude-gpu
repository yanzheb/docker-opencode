# Start from the official Docker sandbox template for Claude Code.
# This already includes Claude Code, Node.js, Python, Git, Go, and dev tools.
FROM docker/sandbox-templates:claude-code

USER root

# Set NVIDIA environment variables so the container requests GPU access.
# The NVIDIA Container Toolkit on the host uses these to inject driver
# libraries at container startup — no CUDA install needed inside the image
# for basic GPU access.
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Enable full 24-bit truecolor so Claude Code renders its theme correctly.
# Without these, colors appear washed out inside containers.
ENV TERM=xterm-256color
ENV COLORTERM=truecolor

# (Optional) Install the CUDA toolkit inside the container if you need
# to compile CUDA code (e.g., PyTorch extensions, custom CUDA kernels).
# Remove this block if you only need runtime GPU access.
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    && wget https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb \
    && dpkg -i cuda-keyring_1.1-1_all.deb \
    && rm cuda-keyring_1.1-1_all.deb \
    && apt-get update && apt-get install -y --no-install-recommends \
    cuda-toolkit \
    && rm -rf /var/lib/apt/lists/*

# Switch back to the default non-root agent user.
USER agent

WORKDIR /workspace
CMD ["/bin/bash"]
