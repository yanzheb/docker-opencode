# Start from the official Docker sandbox template for Claude Code.
# This already includes Claude Code, Node.js, Python, Git, Go, and dev tools.
FROM docker/sandbox-templates:claude-code

# NVIDIA environment variables for GPU access. Empty by default so the
# image works on hosts without a GPU. For a GPU-enabled build, pass:
#   --build-arg NVIDIA_VISIBLE_DEVICES=all
#   --build-arg NVIDIA_DRIVER_CAPABILITIES=compute,utility
# The NVIDIA Container Toolkit on the host reads these at container
# startup and injects the driver libraries. No CUDA install is needed
# inside the image for basic GPU access.
ARG NVIDIA_VISIBLE_DEVICES=""
ARG NVIDIA_DRIVER_CAPABILITIES=""
ENV NVIDIA_VISIBLE_DEVICES=${NVIDIA_VISIBLE_DEVICES}
ENV NVIDIA_DRIVER_CAPABILITIES=${NVIDIA_DRIVER_CAPABILITIES}

# Enable full 24-bit truecolor so Claude Code renders its theme correctly.
# Without these, colors appear washed out inside containers.
ENV TERM=xterm-256color
ENV COLORTERM=truecolor

WORKDIR /workspace
CMD ["/bin/bash"]
