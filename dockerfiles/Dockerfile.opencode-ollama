# Ollama layered on the base image.
# Build the base first, then pass --build-arg BASE_IMAGE=opencode-gpu if needed.
ARG BASE_IMAGE=opencode-nogpu
FROM ${BASE_IMAGE}

# Install Ollama (zstd is required for extraction).
USER root
RUN apt-get update && apt-get install -y --no-install-recommends zstd \
    && curl -fsSL https://ollama.com/install.sh | sh \
    && apt-get clean && rm -rf /var/lib/apt/lists/*
USER agent

WORKDIR /workspace
CMD ["/bin/bash", "-c", "ollama serve > /dev/null 2>&1 & exec /bin/bash"]
