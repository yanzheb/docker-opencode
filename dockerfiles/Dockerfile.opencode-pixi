# Adds the Pixi package manager on top of the base OpenCode image.
# Build the base first (see README Step 5.3), then:
#   docker build -t opencode-pixi \
#       -f dockerfiles/Dockerfile.opencode-pixi dockerfiles/
#
# Pass --build-arg BASE_IMAGE=opencode-gpu to layer on the GPU base instead.
ARG BASE_IMAGE=opencode-nogpu
FROM ${BASE_IMAGE}

# Install Pixi via the official install script. PIXI_NO_PATH_UPDATE skips
# shell-config modifications that are unnecessary in a container. The script
# places the binary under /root/.pixi/bin, so we move it to /usr/local/bin
# for system-wide access regardless of user.
USER root
RUN curl -fsSL https://pixi.sh/install.sh | PIXI_NO_PATH_UPDATE=1 bash \
    && mv /root/.pixi/bin/pixi /usr/local/bin/pixi \
    && rm -rf /root/.pixi
USER agent

WORKDIR /workspace
CMD ["/bin/bash"]
